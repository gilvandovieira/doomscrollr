{
  "name": "@doomscrollr/web",
  "exports": {
    ".": "./src/main.tsx"
  },
  "tasks": {
    "dev": "deno run -A npm:vite --host 0.0.0.0",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview --host 0.0.0.0",
    "check": "deno check src/main.tsx"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.window", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["npm:@types/react@^18.3.24", "npm:@types/react-dom@^18.3.7", "vite/client"]
  },
  "imports": {
    "@clerk/react": "npm:@clerk/react",
    "@doomscrollr/shared/": "../../packages/shared/src/",
    "@tanstack/react-query": "npm:@tanstack/react-query@^5.83.0",
    "@tanstack/react-router": "npm:@tanstack/react-router@^1.130.12",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^4.6.0",
    "autoprefixer": "npm:autoprefixer@^10.4.21",
    "lucide-react": "npm:lucide-react@^0.468.0",
    "react": "npm:react@^18.3.1",
    "react-dom/client": "npm:react-dom@^18.3.1/client",
    "react/jsx-dev-runtime": "npm:react@^18.3.1/jsx-dev-runtime",
    "react/jsx-runtime": "npm:react@^18.3.1/jsx-runtime",
    "tailwindcss": "npm:tailwindcss@^3.4.17",
    "vite": "npm:vite@^7.0.4",
    "zod": "npm:zod@^3.25.76"
  }
}
