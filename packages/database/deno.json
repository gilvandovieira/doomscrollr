{
  "name": "@doomscrollr/database",
  "exports": {
    "./schema": "./src/schema.ts"
  },
  "tasks": {
    "check": "deno check src/schema.ts src/migrate.ts src/seed.ts src/funnel-report.ts",
    "migrate": "deno run --env-file=../../.env.local --allow-env --allow-net --allow-read src/migrate.ts",
    "report:funnel": "deno run --env-file=../../.env.local --allow-env --allow-net src/funnel-report.ts",
    "seed": "deno run --env-file=../../.env.local --allow-env --allow-net src/seed.ts",
    "test": "deno test src"
  },
  "imports": {
    "@doomscrollr/shared/": "../shared/src/",
    "drizzle-orm": "npm:drizzle-orm@^0.44.5",
    "drizzle-orm/pg-core": "npm:drizzle-orm@^0.44.5/pg-core",
    "postgres": "npm:postgres@^3.4.7"
  }
}
